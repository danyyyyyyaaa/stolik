{
  "name": "stolik",
  "version": "0.1.0",
  "private": true,
  "description": "Polish restaurant booking platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:web": "npm run dev --workspace=apps/web-dashboard",
    "dev:mobile": "EXPO_USE_METRO_WORKSPACE_ROOT=1 npm run start --workspace=apps/mobile",
    "build:api": "npm run build --workspace=packages/api",
    "build:web": "npm run build --workspace=apps/web-dashboard"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "expo": "~54.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "dependencies": {
    "expo": "~54.0.0"
  }
}
