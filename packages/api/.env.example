# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/stolik"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-secret-string-min-32-chars"

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── TWILIO (SMS/WhatsApp reminders) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+48..."

# ─── STRIPE (subscriptions + deposits) ───────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── PRZELEWY24 ───────────────────────────────────────────────────────────────
P24_MERCHANT_ID=""
P24_POS_ID=""
P24_CRC=""

# ─── CLOUDFLARE R2 (photo storage) ───────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="stolik-images"

# ─── APP ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
