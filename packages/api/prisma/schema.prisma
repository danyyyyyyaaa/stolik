// This is your Prisma schema file
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── RESTAURANT ───────────────────────────────────────────────────────────────
model Restaurant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  cuisine     String   // italian | polish | japanese | french | ...
  district    String
  city        String   @default("Warszawa")
  address     String
  phone       String?
  email       String?
  website     String?
  instagram   String?
  priceRange  String   @default("$$") // $ | $$ | $$$ | $$$$
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  emoji       String?
  coverImage  String?
  images      String[] // Cloudflare R2 URLs
  isActive    Boolean  @default(true)
  isPremium   Boolean  @default(false)
  plan        String   @default("free") // free | pro | business
  planStatus  String   @default("active")  // active | past_due | cancelled

  // Google Places
  googlePlaceId          String?
  googleRating           Float?
  googleReviewCount      Int?
  googleReviewsCache     Json?
  googleReviewsUpdatedAt DateTime?
  isPublished            Boolean @default(false)
  latitude               Float?
  longitude              Float?

  // Stripe
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Opening hours
  openMonday    String? // "12:00-23:00"
  openTuesday   String?
  openWednesday String?
  openThursday  String?
  openFriday    String?
  openSaturday  String?
  openSunday    String?

  // Booking settings
  slotDuration     Int @default(90)  // minutes
  maxGuestsPerSlot Int @default(20)
  minAdvanceHours  Int @default(1)
  maxAdvanceDays   Int @default(30)
  depositRequired  Boolean @default(false)
  depositAmount    Float?

  // Birthday perks
  birthdayPerkEnabled     Boolean @default(false)
  birthdayPerkDescription String?

  // Parking
  hasParking      Boolean @default(false)
  parkingDetails  String?

  status    String   @default("active") // "draft" | "active" | "suspended"

  googleSyncEnabled Boolean  @default(false)
  lastGoogleSync    DateTime?
  notifPrefs        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner     User         @relation(fields: [ownerId], references: [id])
  ownerId   String
  partner   Partner?     @relation(fields: [partnerId], references: [id])
  partnerId String?
  tables    Table[]
  bookings  Booking[]
  guests    GuestProfile[]
  reviews           Review[]
  staff             StaffMember[]
  menuCategories    MenuCategory[]
  abandonedBookings AbandonedBooking[]
  restaurantStaff   RestaurantStaff[]
  googleReviews     GoogleReview[]
  integrations      Integration[]
  apiKeys           ApiKey[]
  smsTemplates      SmsTemplate[]
  favorites         UserFavorite[]
  waitlist          Waitlist[]
  deals             RestaurantDeal[]
  promotion         RestaurantPromotion?
  events            RestaurantEvent[]

  @@index([partnerId])
  @@index([ownerId])
  @@index([status])
  @@index([isActive])
  @@map("restaurants")
}

// ─── TABLE ────────────────────────────────────────────────────────────────────
model Table {
  id           String  @id @default(cuid())
  name         String  // "Stół 1", "A1", "Taras 3"
  capacity     Int
  minCapacity  Int     @default(1)
  isActive     Boolean @default(true)
  posX         Float?  // Floor plan position
  posY         Float?
  shape        String  @default("round") // round | square | rectangle

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  bookings     Booking[]

  @@map("tables")
}

// ─── USER (guest or restaurant owner) ────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  phone       String?
  firstName   String
  lastName    String
  avatarUrl      String?
  expoPushToken  String?
  lastActiveAt   DateTime?
  role        String   @default("guest") // guest | owner | admin
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  lastLoginAt DateTime?
  passwordHash String?
  googleId    String?  @unique
  language    String   @default("pl")
  dateOfBirth  DateTime?
  referralCode String?  @unique
  referredById String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurants         Restaurant[]
  bookings            Booking[]
  reviews             Review[]
  refreshTokens       RefreshToken[]
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]
  abandonedBookings   AbandonedBooking[]
  restaurantStaff     RestaurantStaff[]
  favorites           UserFavorite[]
  phoneVerifications  PhoneVerification[]
  waitlistEntries     Waitlist[]
  referralsGiven      Referral[]          @relation("Referrer")
  referralsReceived   Referral[]          @relation("Referred")

  @@map("users")
}

// ─── EMAIL VERIFICATION ───────────────────────────────────────────────────────
model EmailVerification {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  newEmail  String?   // set when used for email-change flow (null = initial registration)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@map("email_verifications")
}

// ─── PHONE VERIFICATION ───────────────────────────────────────────────────────
model PhoneVerification {
  id        String    @id @default(uuid())
  code      String
  userId    String
  newPhone  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("phone_verifications")
}

// ─── REFRESH TOKEN ────────────────────────────────────────────────────────────
model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── BOOKING ──────────────────────────────────────────────────────────────────
model Booking {
  id          String   @id @default(cuid())
  bookingRef  String   @unique // #ST1234
  status      String   @default("pending") // pending | confirmed | cancelled | completed | no_show
  date        DateTime
  time        String   // "19:00"
  guestCount  Int
  duration    Int      @default(90) // minutes
  notes              String?
  specialRequests    String?   // free-text allergy / dietary notes
  seatingPreference  String?   // window | kids | quiet | wheelchair
  allergies          String[]  // ["gluten-free","vegan",...]
  source      String   @default("app") // app | widget | manual | instagram
  isBirthdayBooking Boolean @default(false)
  shortCode   String?  @unique // 8-char public share code

  // Guest info (may not be registered user)
  guestName   String
  guestPhone  String
  guestEmail  String?

  // Push notifications
  pushReminderSent Boolean @default(false)

  // Payment
  depositPaid     Boolean @default(false)
  depositAmount   Float?
  stripePaymentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  table        Table?     @relation(fields: [tableId], references: [id])
  tableId      String?
  user         User?      @relation(fields: [userId], references: [id])
  userId       String?
  reminders    Reminder[]
  messages     BookingMessage[]

  @@index([restaurantId, date])
  @@index([restaurantId, status])
  @@index([userId])
  @@index([date])
  @@map("bookings")
}

// ─── GUEST PROFILE (CRM) ──────────────────────────────────────────────────────
model GuestProfile {
  id           String   @id @default(cuid())
  phone        String
  name         String?
  email        String?
  notes        String?
  tags         String[] // ["vip", "vegetarian", "birthday"]
  visitCount   Int      @default(0)
  noShowCount  Int      @default(0)
  isVip        Boolean  @default(false)
  isBlocked    Boolean  @default(false)
  lastVisit    DateTime?

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, restaurantId])
  @@map("guest_profiles")
}

// ─── REMINDER ────────────────────────────────────────────────────────────────
model Reminder {
  id        String   @id @default(cuid())
  type      String   // sms | whatsapp | email
  sentAt    DateTime?
  status    String   @default("pending") // pending | sent | failed

  booking   Booking @relation(fields: [bookingId], references: [id])
  bookingId String

  @@map("reminders")
}

// ─── REVIEW ──────────────────────────────────────────────────────────────────
model Review {
  id             String    @id @default(cuid())
  rating         Int       // 1-5
  comment        String?
  isVisible      Boolean   @default(true)
  ownerReply     String?
  ownerRepliedAt DateTime?
  createdAt      DateTime  @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  user         User       @relation(fields: [userId], references: [id])
  userId       String

  @@map("reviews")
}

// ─── MENU ────────────────────────────────────────────────────────────────────
model MenuCategory {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  sortOrder    Int        @default(0)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  items        MenuItem[]
  createdAt    DateTime   @default(now())

  @@map("menu_categories")
}

model MenuItem {
  id          String       @id @default(cuid())
  categoryId  String
  name        String
  description String?
  price       Float
  imageUrl    String?
  available   Boolean      @default(true)
  sortOrder   Int          @default(0)
  photoUrl    String?
  allergens   String[]     @default([])
  isPopular   Boolean      @default(false)
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  createdAt   DateTime     @default(now())

  @@map("menu_items")
}

// ─── STAFF ───────────────────────────────────────────────────────────────────
model StaffMember {
  id    String @id @default(cuid())
  role  String // manager | host | waiter
  name  String
  email String

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String

  @@map("staff_members")
}

// ─── PASSWORD RESET ──────────────────────────────────────────────────────────
model PasswordReset {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@map("password_resets")
}

// ─── ABANDONED BOOKING ───────────────────────────────────────────────────────
model AbandonedBooking {
  id               String     @id @default(uuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId     String
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  date             String?
  time             String?
  guests           Int?
  notificationSent Boolean    @default(false)
  createdAt        DateTime   @default(now())

  @@index([userId])
  @@index([notificationSent, createdAt])
  @@map("abandoned_bookings")
}

// ─── PARTNER ─────────────────────────────────────────────────────────────────
model Partner {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  company     String?
  commission  Float    @default(10)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurants Restaurant[]

  @@map("partners")
}

// ─── RESTAURANT STAFF (dashboard invitations) ────────────────────────────────
model RestaurantStaff {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String
  role         String   @default("staff") // "manager" | "staff"
  invitedBy    String?
  inviteToken  String?  @unique
  inviteStatus String   @default("pending") // "pending" | "accepted" | "declined"
  createdAt    DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@index([inviteToken])
  @@map("restaurant_staff")
}

// ─── GOOGLE REVIEW ───────────────────────────────────────────────────────────
model GoogleReview {
  id             String   @id @default(uuid())
  restaurantId   String
  googleReviewId String   @unique
  authorName     String
  authorPhoto    String?
  rating         Int
  text           String?
  publishedAt    DateTime
  language       String?
  fetchedAt      DateTime @default(now())

  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, rating])
  @@map("google_reviews")
}

// ─── INTEGRATION ─────────────────────────────────────────────────────────────
model Integration {
  id           String   @id @default(uuid())
  restaurantId String
  provider     String
  credentials  Json
  config       Json
  status       String   @default("active")
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, provider])
  @@map("integrations")
}

// ─── API KEY ──────────────────────────────────────────────────────────────────
model ApiKey {
  id           String   @id @default(uuid())
  restaurantId String
  key          String   @unique
  name         String   @default("Default")
  lastUsedAt   DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("api_keys")
}

// ─── SMS TEMPLATE ─────────────────────────────────────────────────────────────
model SmsTemplate {
  id           String   @id @default(uuid())
  restaurantId String
  type         String
  language     String
  template     String
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, type, language])
  @@map("sms_templates")
}

// ─── USER FAVORITE ────────────────────────────────────────────────────────────
model UserFavorite {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String
  createdAt    DateTime @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@map("user_favorites")
}

// ─── WAITLIST ─────────────────────────────────────────────────────────────────
model Waitlist {
  id           String    @id @default(cuid())
  restaurantId String
  date         DateTime
  timeSlot     String    // "19:00"
  partySize    Int
  guestName    String
  guestPhone   String
  guestEmail   String?
  userId       String?
  status       String    @default("waiting") // waiting | notified | expired | booked
  notifiedAt   DateTime?
  createdAt    DateTime  @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([restaurantId, date, timeSlot])
  @@map("waitlist")
}

// ─── REFERRAL ────────────────────────────────────────────────────────────────
model Referral {
  id           String    @id @default(cuid())
  referrerId   String
  referredId   String
  status       String    @default("pending") // pending | completed
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  referrer     User      @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred     User      @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
  @@index([referredId])
  @@map("referrals")
}

// ─── RESTAURANT DEAL ─────────────────────────────────────────────────────────
model RestaurantDeal {
  id           String    @id @default(cuid())
  restaurantId String
  title        String
  description  String?
  discountType String    @default("percent") // percent | fixed | freeitem
  discountValue Float?
  code         String?
  validFrom    DateTime?
  validUntil   DateTime?
  isActive     Boolean   @default(true)
  maxUses      Int?
  usedCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("restaurant_deals")
}

// ─── RESTAURANT EVENT ────────────────────────────────────────────────────────
model RestaurantEvent {
  id              String   @id @default(cuid())
  restaurantId    String
  title           String
  description     String?
  date            DateTime
  startTime       String   // "19:00"
  endTime         String?  // "23:00"
  maxGuests       Int?
  pricePerPerson  Float?
  imageUrl        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, date])
  @@map("restaurant_events")
}

// ─── BOOKING MESSAGE ─────────────────────────────────────────────────────────
model BookingMessage {
  id         String   @id @default(cuid())
  bookingId  String
  senderId   String
  senderRole String   // "restaurant" | "guest"
  message    String
  createdAt  DateTime @default(now())

  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_messages")
}

// ─── RESTAURANT PROMOTION (ADS) ──────────────────────────────────────────────
model RestaurantPromotion {
  id           String    @id @default(cuid())
  restaurantId String    @unique
  isActive     Boolean   @default(false)
  startsAt     DateTime?
  endsAt       DateTime?
  budget       Float?
  impressions  Int       @default(0)
  clicks       Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("restaurant_promotions")
}
