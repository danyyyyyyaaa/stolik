{
  "expo": {
    "name": "Dinto",
    "slug": "dinto-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dinto",
    "web": {
      "bundler": "metro"
    },
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0D1117"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pl.dinto.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1117"
      },
      "package": "pl.dinto.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Dinto needs access to your photo library to update your profile picture.",
          "cameraPermission": "Dinto needs access to your camera to take a profile picture."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#238636",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Dinto"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
